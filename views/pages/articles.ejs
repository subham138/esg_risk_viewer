<%- include('../templates/header.ejs', {header: "Home" , header_url: "/dashboard" , sub_header: header, sub_header_url: header_url, sub_sub_header: sub_header, show_br: true}) %>

<style>
    :root {
        --primary-color: #316379;
        --secondary-color: #424f6f;
        --white: #ffffff;
        --bg-light: #f8f9fa;
        --border-color: #eee;
        --tag-bg: #e8f4f8;
        --text-muted: #777;
    }

    .articles-container {
        padding: 0px 20px;
        max-width: 1000px;
        margin: 0 auto;
    }

    .article-row {
        background: var(--white);
        border-radius: 15px;
        overflow: hidden;
        display: flex;
        margin-bottom: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        transition: transform 0.3s ease;
        border: 1px solid var(--border-color);
    }

    .article-row:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.1);
    }

    .article-image-wrapper {
        width: 15%;
        min-width: 120px;
        position: relative;
        overflow: hidden;
    }

    .article-image {
        width: 100%;
        height: 100%;
        object-fit: contain;
        transition: transform 0.5s ease;
    }

    .article-row:hover .article-image {
        transform: scale(1.05);
    }

    .article-content {
        width: 85%;
        padding: 15px 20px;
        display: flex;
        flex-direction: column;
    }

    .article-tag {
        display: inline-block;
        background: var(--tag-bg);
        color: var(--primary-color);
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 12px;
        align-self: flex-start;
    }

    .article-heading {
        font-size: 20px;
        font-weight: 700;
        color: var(--primary-color);
        margin-bottom: 10px;
        line-height: 1.3;
    }

    .article-description {
        color: #555;
        font-size: 15px;
        line-height: 1.6;
        margin-bottom: 20px;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .article-footer {
        margin-top: auto;
        padding-top: 20px;
        border-top: 1px solid var(--border-color);
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
        color: var(--text-muted);
    }

    .posted-by {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .posted-by i {
        width: 14px;
        height: 14px;
    }

    @media (max-width: 768px) {
        .article-row {
            flex-direction: column;
        }
        .article-image-wrapper {
            width: 100%;
            height: 200px;
        }
        .article-content {
            width: 100%;
        }
    }
</style>

<div class="articles-container">
    <div class="row mb-4">
        <div class="col-12">
            <h2 style="color: var(--primary-color); font-weight: 700;">Latest Articles</h2>
            <p class="text-muted">In-depth guides and analysis on the evolving ESG landscape.</p>
        </div>
    </div>

    <!-- Article 1 -->
    <div class="article-row">
        <div class="article-image-wrapper">
            <img src="/images/other-images/Picture1.png" alt="SMEs" class="article-image">
        </div>
        <div class="article-content">
            <span class="article-tag">SMEs</span>
            <h3 class="article-heading">Sustainability Reporting for SMEs: Is your Business at an Upstream or Downstream Control Point?</h3>
            <p class="article-description">This article explains the reasons why even SMEs should engage with the management and reporting of their sustainability risks and opportunities.</p>
            <a href="/files/Sustainalility-Reporting-for-SMEs.pdf" target="_blank">Read More..</a>
        </div>
    </div>

    <!-- Article 2 -->
    <div class="article-row">
        <div class="article-image-wrapper">
            <img src="/images/other-images/Picture2.png" alt="Funding for SMEs" class="article-image">
        </div>
        <div class="article-content">
            <span class="article-tag">Funding for SMEs</span>
            <h3 class="article-heading">Reporting on Financed Emissions: The Move Towards the Highest Data Quality and Implications for Organisations Seeking to Attract Funding</h3>
            <p class="article-description">Financed emissions represent the GHG emissions associated with the lending and investment activities of financial institutions. We illustrate the implications of financed emissions reporting on the ability of SMEs to attract funding.</p>
            <a href="/files/Financed-Emissions.pdf" target="_blank">Read More..</a>
        </div>
    </div>

    <!-- Article 3 -->
    <div class="article-row">
        <div class="article-image-wrapper">
            <img src="/images/other-images/Picture3.png" alt="GHG Emissions" class="article-image">
        </div>
        <div class="article-content">
            <span class="article-tag">GHG Emissions</span>
            <h3 class="article-heading">Getting Started with GHG Emissions</h3>
            <p class="article-description">In this article, we highlight the process of managing GHG emissions for organisations, from the determination of organisational boundaries to the establishment of transitions plans.</p>
            <a href="/files/Getting-Started-with-GHG-Emissions.pdf" target="_blank">Read More..</a>
        </div>
    </div>

    <!-- Article 4 -->
    <div class="article-row">
        <div class="article-image-wrapper">
            <img src="/images/other-images/Picture4.png" alt="Value creation" class="article-image">
        </div>
        <div class="article-content">
            <span class="article-tag">Value creation</span>
            <h3 class="article-heading">Sustainability and Value Creation</h3>
            <p class="article-description">This article highlights the benefits of sustainability for SMEs and explains the steps involved in the voluntary adoption of sustainability reporting frameworks.</p>
            <a href="/files/Sustainalility-and-Value-Creation.pdf" target="_blank">Read More..</a>
        </div>
    </div>
</div>

<%- include('../templates/footer.ejs') %>

<script>
    feather.replace();
</script>
