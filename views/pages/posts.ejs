<%- include('../templates/header.ejs', {header: "Home" , header_url: "/dashboard" , sub_header: header, sub_header_url: header_url, sub_sub_header: sub_header, show_br: true}) %>

<style>
    :root {
        --primary-color: #316379;
        --secondary-color: #424f6f;
        --white: #ffffff;
        --bg-light: #f8f9fa;
        --border-color: #e8eef5;
        --tag-bg: #f8f0f0;
        --post-tag-color: #c03b39;
        --text-muted: #777;
        --shadow-sm: 0 2px 8px rgba(49, 99, 121, 0.08);
        --shadow-md: 0 8px 24px rgba(49, 99, 121, 0.12);
    }

    .posts-container {
        padding: 40px 20px;
        max-width: 1200px;
        margin: 0 auto;
        background: linear-gradient(135deg, #f8fafb 0%, #ffffff 100%);
        border-radius: 16px;
    }

    .posts-header {
        margin-bottom: 50px;
        text-align: center;
    }

    .posts-header h2 {
        color: var(--primary-color);
        font-weight: 700;
        font-size: 32px;
        margin-bottom: 12px;
        letter-spacing: -0.5px;
    }

    .posts-header p {
        color: var(--text-muted);
        font-size: 16px;
        line-height: 1.6;
    }

    .posts-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 28px;
        margin-bottom: 30px;
    }

    .post-card-wrapper {
        background: var(--white);
        border-radius: 14px;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .post-card-wrapper:hover {
        box-shadow: var(--shadow-md);
        transform: translateY(-6px);
        border-color: var(--primary-color);
    }

    .iframe-wrapper {
        flex: 1;
        overflow: hidden;
        border-bottom: 1px solid var(--border-color);
        background: var(--bg-light);
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 400px;
    }

    .iframe-wrapper iframe {
        width: 100% !important;
        height: 100% !important;
        border: none !important;
        border-radius: 0 !important;
    }

    @media (max-width: 1024px) {
        .posts-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }
    }

    @media (max-width: 768px) {
        .posts-container {
            padding: 30px 16px;
        }

        .posts-header h2 {
            font-size: 26px;
        }

        .posts-grid {
            grid-template-columns: 1fr;
            gap: 20px;
        }

        .iframe-wrapper {
            min-height: 500px;
        }
    }

    @media (max-width: 480px) {
        .posts-container {
            padding: 20px 12px;
        }

        .posts-header h2 {
            font-size: 22px;
        }

        .posts-header p {
            font-size: 14px;
        }

        .iframe-wrapper {
            min-height: 400px;
        }
    }
</style>

<div class="posts-container">
    <div class="posts-header">
        <h2>Industry Updates</h2>
        <p>Stay informed with the latest bite-sized news and community updates from industry leaders.</p>
    </div>

    <div class="posts-grid">
        <div class="post-card-wrapper">
            <div class="iframe-wrapper">
                <iframe src="https://www.linkedin.com/embed/feed/update/urn:li:ugcPost:7323671792542261248"
                    frameborder="0" allowfullscreen="" title="LinkedIn post"></iframe>
            </div>
        </div>

        <div class="post-card-wrapper">
            <div class="iframe-wrapper">
                <iframe src="https://www.linkedin.com/embed/feed/update/urn:li:ugcPost:7329991521842118657"
                    frameborder="0" allowfullscreen="" title="LinkedIn post"></iframe>
            </div>
        </div>

        <div class="post-card-wrapper">
            <div class="iframe-wrapper">
                <iframe src="https://www.linkedin.com/embed/feed/update/urn:li:ugcPost:7318037081627217920"
                    frameborder="0" allowfullscreen="" title="LinkedIn post"></iframe>
            </div>
        </div>

        <div class="post-card-wrapper">
            <div class="iframe-wrapper">
                <iframe src="https://www.linkedin.com/embed/feed/update/urn:li:ugcPost:7317286691650560000"
                    frameborder="0" allowfullscreen="" title="LinkedIn post"></iframe>
            </div>
        </div>
    </div>
</div>

