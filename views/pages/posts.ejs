<%- include('../templates/header.ejs', {header: "Home" , header_url: "/dashboard" , sub_header: header, sub_header_url: header_url, sub_sub_header: sub_header, show_br: true}) %>

<style>
    :root {
        --primary-color: #316379;
        --secondary-color: #424f6f;
        --white: #ffffff;
        --bg-light: #f8f9fa;
        --border-color: #eee;
        --tag-bg: #f8f0f0;
        --post-tag-color: #c03b39;
        --text-muted: #777;
    }

    .posts-container {
        padding: 0px 20px;
        max-width: 1000px;
        margin: 0 auto;
    }

    .post-row {
        background: var(--white);
        border-radius: 12px;
        overflow: hidden;
        display: flex;
        margin-bottom: 20px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        transition: all 0.3s ease;
        border: 1px solid var(--border-color);
    }

    .post-row:hover {
        transform: scale(1.01);
        box-shadow: 0 6px 20px rgba(0,0,0,0.08);
    }

    .post-image-wrapper {
        width: 12%;
        min-width: 100px;
        background: #f0f4f7;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .post-image {
        width: 100%;
        height: 100%;
        object-fit: contain;
        transition: transform 0.5s ease;
    }

    .post-content {
        width: 88%;
        padding: 10px 20px;
    }

    .post-tag {
        display: inline-block;
        background: var(--tag-bg);
        color: var(--post-tag-color);
        padding: 3px 10px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .post-heading {
        font-size: 20px;
        font-weight: 700;
        color: var(--primary-color);
        margin-bottom: 10px;
    }

    .post-description {
        color: #666;
        font-size: 14px;
        line-height: 1.5;
        margin-bottom: 15px;
    }

    .post-footer {
        display: flex;
        gap: 20px;
        font-size: 12px;
        color: var(--text-muted);
        border-top: 1px solid #f9f9f9;
        padding-top: 15px;
    }

    .footer-item {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .footer-item i {
        width: 14px;
        height: 14px;
    }

    @media (max-width: 768px) {
        .post-row {
            flex-direction: column;
        }
        .post-image-wrapper {
            width: 100%;
            height: 180px;
        }
        .post-content {
            width: 100%;
        }
    }
</style>

<div class="posts-container">
    <div class="row mb-4">
        <div class="col-12">
            <h2 style="color: var(--primary-color); font-weight: 700;">Industry Updates</h2>
            <p class="text-muted">Stay informed with the latest bite-sized news and community updates.</p>
        </div>
    </div>

    <!-- Post 1 -->
    <div class="post-row">
        <div class="post-image-wrapper">
            <img src="/images/other-images/Scope_2_Icon.png" alt="Update" class="post-image" style="padding: 20px; object-fit: contain;">
        </div>
        <div class="post-content">
            <span class="post-tag">Policy Update</span>
            <h3 class="post-heading">New EU CSRD Guidelines Released for 2026</h3>
            <p class="post-description">The European Commission has provided new technical standards for Scope 3 emissions reporting, effective for the 2026 fiscal year reporting cycle.</p>
            <div class="post-footer">
                <div class="footer-item">
                    <i data-feather="user"></i>
                    <span>By System News</span>
                </div>
                <div class="footer-item">
                    <i data-feather="clock"></i>
                    <span>2 hours ago</span>
                </div>
                <div class="footer-item">
                    <i data-feather="message-circle"></i>
                    <span>12 Comments</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Post 2 -->
    <div class="post-row">
        <div class="post-image-wrapper">
            <img src="/images/other-images/leaf_esg.webp" alt="Event" class="post-image">
        </div>
        <div class="post-content">
            <span class="post-tag">Community</span>
            <h3 class="post-heading">ESG Leaders Summit: London 2025</h3>
            <p class="post-description">Join us next month as industry leaders gather to discuss the intersection of AI and sustainability reporting. Registration is now open for all premium users.</p>
            <div class="post-footer">
                <div class="footer-item">
                    <i data-feather="user"></i>
                    <span>By Event Team</span>
                </div>
                <div class="footer-item">
                    <i data-feather="clock"></i>
                    <span>Oct 20, 2025</span>
                </div>
                <div class="footer-item">
                    <i data-feather="share-2"></i>
                    <span>45 Shares</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Post 3 -->
    <div class="post-row">
        <div class="post-image-wrapper">
            <img src="/images/other-images/risk_info.png" alt="Data" class="post-image" style="padding: 20px; object-fit: contain;">
        </div>
        <div class="post-content">
            <span class="post-tag">Insights</span>
            <h3 class="post-heading">Q3 Global Risk Sentiment Analysis</h3>
            <p class="post-description">Our latest data analysis show a 15% increase in climate-related financial risk concerns among manufacturing sector stakeholders.</p>
            <div class="post-footer">
                <div class="footer-item">
                    <i data-feather="user"></i>
                    <span>By Data Analyst</span>
                </div>
                <div class="footer-item">
                    <i data-feather="clock"></i>
                    <span>Oct 18, 2025</span>
                </div>
                <div class="footer-item">
                    <i data-feather="heart"></i>
                    <span>128 Likes</span>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../templates/footer.ejs') %>

<script>
    feather.replace();
</script>
